# Azure OpenAI / Azure Foundry Configuration
# Required settings:
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# Optional: API version (defaults to 2024-12-01-preview)
# AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Authentication:
# - Azure AD (recommended): Run 'az login' - no additional config needed
# - API Key: Uncomment below if key auth is enabled on your resource
# AZURE_OPENAI_API_KEY=your-azure-openai-key

# Optional: For YouTube Data API (higher rate limits)
# YOUTUBE_API_KEY=your-youtube-api-key

# Optional: Proxy for YouTube transcript API (required in cloud environments)
# YouTube blocks transcript requests from cloud IPs. Use a SOCKS5 or HTTP proxy.
# Surfshark example: socks5://username:password@socks-us.prod.surfshark.com:1080
# PROXY_URL=socks5://user:pass@proxy-host:1080
