# Azure OpenAI Configuration (Required)
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_TENANT_ID=your-tenant-id

# Optional: API Key Authentication (if not using Azure AD)
# AZURE_OPENAI_API_KEY=your-api-key-here

# Optional: Proxy for Cloud Environments
# YouTube blocks data center IPs - use a proxy to bypass
#
# Option 1: Tor (free)
#   Local machine:
#     1. Run: docker run -p 9050:9050 -d dperson/torproxy
#     2. Set: PROXY_URL=socks5://127.0.0.1:9050
#
#   From devcontainer:
#     1. On host, run: docker run -d dperson/torproxy
#     2. Get container IP: docker inspect <container_name> --format '{{range .NetworkSettings.Networks}}{{.IPAddress}}{{end}}'
#     3. Set: PROXY_URL=socks5://<container_ip>:9050
#     Note: Container IP may change on Docker restart
#
# Option 2: Residential proxy ($5-10/GB)
#   PROXY_URL=http://user:pass@your-residential-proxy:port

# Optional: LLM Sampling Settings
# LLM_TEMPERATURE=0.7  # 0.0=deterministic, 1.0=creative
# LLM_SEED=42          # Fixed seed for reproducible outputs

# Optional: YouTube Data API (for higher rate limits)
# YOUTUBE_API_KEY=your-youtube-api-key
